{
  "manifest_version": 3,
  "name": "Text Fall Extension",
  "version": "1.0",
  "description": "Makes all the text on the page fall with animation when a hotkey is pressed.",
    "permissions": ["scripting", "activeTab"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "trigger-text-fall": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y"
      },
      "description": "Trigger text fall effect"
    }
  }
}
